<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.task.meeting.repository.AttendeeMapper">
    <insert id="insertAttendee" parameterType="com.task.meeting.entity.Attendee">
        INSERT INTO T_MEETING_ATTENDEES ( meeting_id, empino )
        VALUES ( #{meetingId}, #{empino} )
    </insert>

    <delete id="deleteAttendeesByMeetingId" parameterType="long">
        DELETE FROM T_MEETING_ATTENDEES
        WHERE meeting_id = #{meetingId}
    </delete>
</mapper>
